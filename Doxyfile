PROJECT_NAME           = "serval"
PROJECT_BRIEF          = "A minimal yet efficient HTTP/1.1 server library providing convenient abstractions, asynchronous I/O, multithreading support, and a flexible request handler interface for custom implementations."
OUTPUT_DIRECTORY       = docs
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
USE_MDFILE_AS_MAINPAGE = lib/README.md
INPUT                  = lib/
RECURSIVE              = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES

FILE_PATTERNS          = *.h *.hpp *.cpp
OPTIMIZE_OUTPUT_FOR_C  = NO